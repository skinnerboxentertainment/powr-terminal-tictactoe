{
  "name": "powr-terminal-tictactoe",
  "version": "1.0.0",
  "private": true,
  "description": "POWR Terminal — WarGames-style tic-tac-toe on a Cold War CRT terminal. PixiJS v8 + TypeScript.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "cd tools/ts-compiler-mcp && npm install",
    "sfxr": "tsx tools/audio-pipeline/src/sfxr.ts",
    "export-graph": "tsx tools/graph-viewer/export-graph.ts"
  },
  "dependencies": {
    "@automagically/narrative-core": "file:packages/narrative-core",
    "howler": "^2.2.4",
    "jsfxr": "^1.4.1",
    "pixi.js": "^8.19.0",
    "playwright": "^1.61.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/howler": "^2.2.13",
    "@types/node": "^26.0.1",
    "jsdom": "^29.1.1",
    "netlify-cli": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
